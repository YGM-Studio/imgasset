{
  "name": "@yigemo/imgasset",
  "version": "1.4.0",
  "description": "OpenAI-compatible image asset generation and compression CLI.",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "bin": {
    "imgasset": "bin/imgasset.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "docs",
    "LICENSE",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YGM-Studio/imgasset.git"
  },
  "bugs": {
    "url": "https://github.com/YGM-Studio/imgasset/issues"
  },
  "homepage": "https://github.com/YGM-Studio/imgasset#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run test",
    "check": "pnpm run build && pnpm run test && node bin/imgasset.js --help",
    "ci": "pnpm run check && pnpm audit --prod",
    "release": "node scripts/release.mjs",
    "prepack": "pnpm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "openai",
    "image",
    "tinify",
    "tinypng",
    "cli",
    "assets"
  ],
  "author": "YGM Studio",
  "license": "MIT",
  "dependencies": {
    "@yigemo/tinify-cli": "^0.1.0",
    "commander": "^14.0.2",
    "undici": "^7.16.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
